<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- EDIT PATHS BELOW: replace /path/to with your actual install location -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.immich.ml-metal</string>
    <key>ProgramArguments</key>
    <array>
        <string>/path/to/immich-apple-silicon/ml/venv/bin/python3</string>
        <string>-m</string>
        <string>src.main</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/path/to/immich-apple-silicon/ml</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>ML_PORT</key>
        <string>3004</string>
        <key>ML_MAX_CONCURRENT_REQUESTS</key>
        <string>16</string>
        <key>PATH</key>
        <string>/path/to/immich-apple-silicon/ml/venv/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/immich-ml-metal.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/immich-ml-metal.err</string>
</dict>
</plist>
